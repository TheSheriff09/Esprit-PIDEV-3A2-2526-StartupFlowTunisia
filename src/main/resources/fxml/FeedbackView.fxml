<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16" style="-fx-padding:24;" styleClass="main"
      stylesheets="@../css/mentorship.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.gui.SessionFeedbackController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <Label styleClass="section-title" text="💬  Session Feedback"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" styleClass="search-field"
                   promptText="🔍  Search by strengths, weaknesses…"
                   onKeyReleased="#onSearch"/>
    </HBox>

    <!-- Form card (mentor writes feedback; evaluator sees it read-only) -->
    <VBox styleClass="glass-card" spacing="12">
        <padding><Insets bottom="20" left="22" right="22" top="18"/></padding>
        <Label styleClass="section-sub" text="SUBMIT / EDIT FEEDBACK  (Mentor)"/>

        <GridPane hgap="16" vgap="10">
            <Label text="Session *"  styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="sessionCombo" prefWidth="260" promptText="Pick your session…"
                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Mentor ID *" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="mentorIDField" promptText="auto-filled" prefWidth="120"
                       GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <!-- Removed Date Selection for Mentor (auto-set to today) -->
            <Label fx:id="dateLabel" text="Date: Today" styleClass="field-label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
            <DatePicker fx:id="feedbackDatePicker" visible="false" managed="false"
                        GridPane.columnIndex="5" GridPane.rowIndex="0"/>

            <Label text="Score"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="5">
                <Slider fx:id="scoreSlider" min="0" max="100" value="50" prefWidth="280"
                        style="-fx-accent:#7357ff;"/>
                <Label fx:id="scoreLabel" text="50" style="-fx-font-weight:700;-fx-font-size:15px;-fx-text-fill:#7357ff;"/>
            </HBox>

            <Label text="Strengths *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextArea fx:id="strengthsArea" prefWidth="220" prefHeight="68"
                      GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Weaknesses"  styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <TextArea fx:id="weaknessesArea" prefWidth="220" prefHeight="68"
                      GridPane.columnIndex="3" GridPane.rowIndex="2"/>

            <Label text="Recommendations" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextArea fx:id="recommendationsArea" prefWidth="220" prefHeight="68"
                      GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Next Actions"    styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
            <TextArea fx:id="nextActionsArea" prefWidth="220" prefHeight="68"
                      GridPane.columnIndex="3" GridPane.rowIndex="3"/>
        </GridPane>

        <Label fx:id="msgLabel" text=""/>

        <HBox fx:id="actionBox" spacing="10">
            <Button text="✏️ Submit"  onAction="#onSubmit" styleClass="btn-primary"/>
            <Button text="🔄 Update" onAction="#onUpdate" styleClass="btn-secondary"/>
            <Button text="🗑 Delete" onAction="#onDelete" styleClass="btn-danger"/>
            <Button text="✖ Clear"  onAction="#onClear"  styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <!-- Table -->
    <TableView fx:id="feedbackTable" VBox.vgrow="ALWAYS"
               onMouseClicked="#onRowSelected" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colID"       text="ID"       prefWidth="55"/>
            <TableColumn fx:id="colSession"  text="Session"  prefWidth="80"/>
            <TableColumn fx:id="colMentor"   text="Mentor"   prefWidth="80"/>
            <TableColumn fx:id="colScore"    text="Score"    prefWidth="80"/>
            <TableColumn fx:id="colDate"     text="Date"     prefWidth="130"/>
            <TableColumn fx:id="colStrengths" text="Strengths" prefWidth="300"/>
        </columns>
        <placeholder><Label text="No feedback yet." style="-fx-text-fill:#9b8acc;"/></placeholder>
    </TableView>

</VBox>
